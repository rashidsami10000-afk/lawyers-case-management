<Window x:Class="LawyerCaseManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lawyer Case Manager"
        MinWidth="600"
        MinHeight="500"
        Width="960"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="Manual"
        Loaded="MainWindow_Loaded">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar navigation -->
        <Border Grid.Column="0" Background="{StaticResource NavyBrush}" VerticalAlignment="Stretch">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,16">
                    <TextBlock Text="Lawyer Case" Foreground="White" FontSize="18" FontWeight="Bold" Margin="16,0,16,0"/>
                    <TextBlock Text="Manager" Foreground="#B3FFFFFF" FontSize="14" Margin="16,0,16,24"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom"
                           Text="Works offline"
                           Foreground="#99FFFFFF"
                           FontSize="11"
                           Margin="16,8,16,16"
                           TextWrapping="Wrap"/>
                <StackPanel x:Name="NavStack" Margin="8,0,8,8" VerticalAlignment="Top">
                    <Button x:Name="NavCases" Content="Cases" Style="{StaticResource SidebarButtonActiveStyle}" Click="NavCases_Click"/>
                    <Button x:Name="NavClients" Content="Clients" Style="{StaticResource SidebarButtonStyle}" Click="NavClients_Click"/>
                    <Button x:Name="NavDocuments" Content="Documents" Style="{StaticResource SidebarButtonStyle}" Click="NavDocuments_Click"/>
                    <Button x:Name="NavNotes" Content="Notes Timeline" Style="{StaticResource SidebarButtonStyle}" Click="NavNotes_Click"/>
                    <Button x:Name="NavCalendar" Content="Calendar" Style="{StaticResource SidebarButtonStyle}" Click="NavCalendar_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content area (fills window; panels scroll internally — avoids content under taskbar) -->
        <Grid Grid.Column="1" Margin="16,12,16,12">
                <!-- CASES VIEW -->
                <Grid x:Name="CasesPanel" Visibility="Visible" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*" MinHeight="200"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Cases" Style="{StaticResource SectionHeaderStyle}"/>
                    <DockPanel Grid.Row="1" Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="Refresh" Style="{StaticResource PrimaryButtonStyle}" Click="RefreshCases_Click"/>
                        <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextGrayBrush}"/>
                        <TextBox x:Name="CaseSearchBox" MinWidth="280" Margin="0,0,12,0"
                                 ToolTip="Search by name, date, court, status, or keyword"
                                 TextChanged="CaseSearchBox_TextChanged"/>
                    </DockPanel>
                    <DataGrid x:Name="CasesGrid" Grid.Row="2" SelectionChanged="CasesGrid_SelectionChanged" MinHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding CaseID}" Width="50"/>
                            <DataGridTextColumn Header="Case Name" Binding="{Binding CaseName}" Width="*"/>
                            <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="120"/>
                            <DataGridTextColumn Header="Court" Binding="{Binding CourtName}" Width="100"/>
                            <DataGridTextColumn Header="Number" Binding="{Binding CaseNumber}" Width="90"/>
                            <DataGridTextColumn Header="Opening" Binding="{Binding OpeningDate, StringFormat=d}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" Margin="0,12,0,0" MaxHeight="320">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Case Details" FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Case Name *" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="CaseNameBox"/>
                                    <TextBlock Text="Client" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="CaseClientCombo" DisplayMemberPath="Name" SelectedValuePath="ClientID"/>
                                    <TextBlock Text="Court Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="CaseCourtBox"/>
                                    <TextBlock Text="Case Number" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="CaseNumberBox"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Opening Date" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker x:Name="CaseOpeningPicker"/>
                                    <TextBlock Text="Status" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="CaseStatusCombo">
                                        <ComboBoxItem Content="Active"/>
                                        <ComboBoxItem Content="Closed"/>
                                        <ComboBoxItem Content="Pending"/>
                                    </ComboBox>
                                    <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox x:Name="CaseNotesBox" Height="72" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="New Case" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="NewCase_Click"/>
                                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="SaveCase_Click"/>
                                <Button Content="Delete" Padding="14,8" Margin="0,0,8,0" Click="DeleteCase_Click"/>
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- CLIENTS VIEW -->
                <Grid x:Name="ClientsPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Clients" Style="{StaticResource SectionHeaderStyle}"/>
                    <DataGrid x:Name="ClientsGrid" Grid.Row="1" MinHeight="200" SelectionChanged="ClientsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ClientID}" Width="50"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" Margin="0,12,0,0" MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Client Details" FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}"/>
                            <TextBlock Text="Name *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="ClientNameBox"/>
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="ClientPhoneBox"/>
                            <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="ClientEmailBox"/>
                            <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="ClientAddressBox"/>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Add Client" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="SaveClient_Click"/>
                                <Button Content="Update" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="UpdateClient_Click"/>
                                <Button Content="Delete" Padding="14,8" Click="DeleteClient_Click"/>
                                <Button Content="Clear" Margin="8,0,0,0" Padding="14,8" Click="ClearClientForm_Click"/>
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- DOCUMENTS VIEW -->
                <Grid x:Name="DocumentsPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Documents" Style="{StaticResource SectionHeaderStyle}"/>
                    <DataGrid x:Name="DocumentsGrid" Grid.Row="1" MinHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding DocID}" Width="50"/>
                            <DataGridTextColumn Header="Case" Binding="{Binding CaseName}" Width="*"/>
                            <DataGridTextColumn Header="Document" Binding="{Binding DocName}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding DocType}" Width="100"/>
                            <DataGridTextColumn Header="Uploaded" Binding="{Binding UploadDate, StringFormat=g}" Width="140"/>
                            <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" Margin="0,12,0,0" MaxHeight="300">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Register Document (simulated PDF upload — stores file path)" FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}"/>
                            <TextBlock Text="Case *" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DocCaseCombo" DisplayMemberPath="CaseName"/>
                            <TextBlock Text="Document Name *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="DocNameBox"/>
                            <TextBlock Text="Document Type" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="DocTypeCombo">
                                <ComboBoxItem Content="Contract"/>
                                <ComboBoxItem Content="Evidence"/>
                                <ComboBoxItem Content="CourtPaper"/>
                            </ComboBox>
                            <TextBlock Text="File Path" Style="{StaticResource FieldLabelStyle}"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse…" Margin="8,0,0,0" Padding="12,6" Click="BrowseDocument_Click"/>
                                <TextBox x:Name="DocPathBox" IsReadOnly="True"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Save Document" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="SaveDocument_Click"/>
                                <Button Content="Delete Selected" Padding="14,8" Click="DeleteDocument_Click"/>
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- NOTES TIMELINE VIEW -->
                <Grid x:Name="NotesPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Notes Timeline" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Chronological list (newest first)" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,8"/>
                    </StackPanel>
                    <ListView x:Name="NotesList" Grid.Row="2" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="0,0,0,1" Padding="12,10" Background="White" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}">
                                            <Run Text="{Binding CaseName}"/>
                                            <Run Text=" · " Foreground="{StaticResource TextGrayBrush}"/>
                                            <Run Text="{Binding CreatedDate, StringFormat=g}" Foreground="{StaticResource TextGrayBrush}" FontWeight="Normal"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Author}" Foreground="{StaticResource TextGrayBrush}" FontSize="12" Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding NoteText}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderGrayBrush}" BorderThickness="1" Margin="0,12,0,0" MaxHeight="240">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Add Note" FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}"/>
                            <TextBlock Text="Case *" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox x:Name="NoteCaseCombo" DisplayMemberPath="CaseName"/>
                            <TextBlock Text="Author" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NoteAuthorBox"/>
                            <TextBlock Text="Note *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NoteTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                <Button Content="Add Note" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Click="SaveNote_Click"/>
                                <Button Content="Delete Selected" Padding="14,8" Click="DeleteNote_Click"/>
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- CALENDAR VIEW -->
                <Grid x:Name="CalendarPanel" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Calendar — Court Dates &amp; Deadlines" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Select a day to see cases with that opening date (court dates / deadlines)." Foreground="{StaticResource TextGrayBrush}"/>
                    </StackPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Calendar x:Name="CourtCalendar" Margin="0,0,24,0" SelectedDatesChanged="CourtCalendar_SelectedDatesChanged"/>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="CalendarDateLabel" Grid.Row="0" FontWeight="SemiBold" Foreground="{StaticResource NavyBrush}" Margin="0,0,0,8"/>
                            <DataGrid x:Name="CalendarCasesGrid" Grid.Row="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Case" Binding="{Binding CaseName}" Width="*"/>
                                    <DataGridTextColumn Header="Court" Binding="{Binding CourtName}" Width="*"/>
                                    <DataGridTextColumn Header="Number" Binding="{Binding CaseNumber}" Width="100"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
        </Grid>
    </Grid>
</Window>
